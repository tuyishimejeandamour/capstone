rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is registered in the admin_users collection
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // Hospitals
    match /hospitals/{hospitalId} {
      allow read: if true; // Offline cache sync reads this
      allow write: if isAdmin(); // Only admins can add/edit hospitals
    }

    // Pending Submissions
    match /pending_submissions/{submissionId} {
      allow read: if isAdmin(); // Only admins can view the moderation queue
      allow create: if request.auth != null; // Any logged in student can submit reviews/costs
      allow update, delete: if isAdmin(); // Only admins can moderate
    }

    // Approved Submissions
    match /approved_submissions/{submissionId} {
      allow read: if true; // Public list of approved reviews for hospital detail pages
      allow write: if isAdmin(); // Only admin portal writes here
    }

    // Admin Users
    match /admin_users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin(); // Only admins can add new admins
    }
  }
}
